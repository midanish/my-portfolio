# Copy this file to ".env" and fill in your values.
# ".env" is gitignored — never commit real secrets.

# Hugging Face token — enables the LLM chatbot. Without it, the bot still works
# via a grounded fallback. Get one at https://huggingface.co/settings/tokens
HF_TOKEN=

# Optional: override the chat model (default: zai-org/GLM-4.7-Flash)
# CHAT_MODEL=zai-org/GLM-4.7-Flash

# Optional: override the local server port (default: 3000)
# PORT=3000
